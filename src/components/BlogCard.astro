---
interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  readingTime: number;
  slug: string;
}

const { title, description, date, category, readingTime, slug } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('uz-UZ', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a
  href={`/maqolalar/${slug}`}
  class="group flex flex-col rounded-2xl border border-dark/10 bg-white p-6 transition-all duration-200 hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5 md:p-7"
>
  <!-- Top: Category + Time -->
  <div class="flex items-center justify-between">
    <span class="rounded-full bg-accent/10 px-3 py-1 text-xs font-medium text-accent">
      {category}
    </span>
    <span class="text-xs text-dark/40">{readingTime} daqiqa</span>
  </div>

  <!-- Title -->
  <h3 class="mt-4 text-lg font-bold leading-snug text-dark transition-colors group-hover:text-accent">
    {title}
  </h3>

  <!-- Description -->
  <p class="mt-2 flex-1 text-sm leading-relaxed text-dark/50 line-clamp-2">
    {description}
  </p>

  <!-- Bottom: Date + Arrow -->
  <div class="mt-5 flex items-center justify-between border-t border-dark/5 pt-4">
    <time datetime={date} class="text-xs text-dark/40">{formattedDate}</time>
    <span class="flex items-center gap-1.5 text-sm font-medium text-accent opacity-0 transition-opacity group-hover:opacity-100">
      O'qish
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </span>
  </div>
</a>
