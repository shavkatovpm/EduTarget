---
---

<section class="relative min-h-screen flex flex-col justify-center overflow-hidden bg-light">
  <!-- Background decoration -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute left-1/2 top-0 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent/10 blur-3xl"></div>
    <div class="absolute bottom-0 right-0 h-[400px] w-[400px] translate-x-1/2 translate-y-1/2 rounded-full bg-accent/5 blur-3xl"></div>
  </div>

  <div class="container-custom py-12 md:py-16 lg:py-20">
    <div class="mx-auto max-w-4xl text-center">
      <!-- Badge -->
      <div class="mb-8 inline-flex items-center gap-1.5 rounded-full border border-accent/20 bg-accent/10 px-3 py-1.5 text-xs font-medium text-accent md:mb-12 md:gap-3 md:px-6 md:py-2.5 md:text-lg">
        <span>Telegram Ads</span>
        <span class="relative flex h-1 w-1 md:h-2 md:w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-75"></span>
          <span class="relative inline-flex h-1 w-1 rounded-full bg-accent md:h-2 md:w-2"></span>
        </span>
        <span>Google Ads & SEO</span>
      </div>

      <!-- Heading - Animated text (grid overlap prevents layout shift) -->
      <div class="grid">
        <h1 class="col-start-1 row-start-1 text-3xl font-bold tracking-tight text-dark sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl">
          <span id="animated-heading" class="inline-block transition-all duration-500" style="filter: blur(0px);">
            Ta'lim markazingizga o'quvchilar oqimini oshiramiz
          </span>
        </h1>
        <span class="col-start-1 row-start-1 invisible font-display text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl" aria-hidden="true">Ta'lim markazingizga o'quvchilar oqimini oshiramiz</span>
        <span class="col-start-1 row-start-1 invisible font-display text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl" aria-hidden="true">Maqsadli reklama orqali real natijalar ko'rsatamiz</span>
        <span class="col-start-1 row-start-1 invisible font-display text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl" aria-hidden="true">Har bir so'mingizdan maksimal foyda olamiz</span>
      </div>

      <!-- Subtitle -->
      <p class="mx-auto mt-6 max-w-2xl text-base text-dark/60 md:text-lg">
        Sizda kuchli kurslar bor. Biz esa ularni to'g'ri auditoriyaga yetkazamiz.
        Faqat ta'lim sohasiga ixtisoslashgan marketing agentligi.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/aloqa"
          class="inline-flex h-12 items-center justify-center rounded-full bg-accent px-8 text-base font-semibold text-white shadow-lg shadow-accent/25 transition-all hover:bg-accent/90 hover:shadow-xl hover:shadow-accent/30"
        >
          Bepul maslahat olish
        </a>
        <a
          href="/#xizmatlar"
          class="hidden h-12 items-center justify-center gap-2 rounded-full border border-dark/10 bg-white px-8 text-base font-semibold text-dark transition-colors hover:bg-dark/5 sm:inline-flex"
        >
          Xizmatlarni ko'rish
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <!-- Stats -->
      <div class="mt-16 grid grid-cols-3 gap-8 border-t border-dark/10 pt-12">
        <div>
          <div class="text-3xl font-bold text-accent md:text-4xl">50+</div>
          <div class="mt-1 text-sm text-dark/60">Ta'lim markazlari</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-accent md:text-4xl">3x</div>
          <div class="mt-1 text-sm text-dark/60">O'quvchilar o'sishi</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-accent md:text-4xl">97%</div>
          <div class="mt-1 text-sm text-dark/60">Mamnun mijozlar</div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const headingTexts = [
    "Ta'lim markazingizga o'quvchilar oqimini oshiramiz",
    "Maqsadli reklama orqali real natijalar ko'rsatamiz",
    "Har bir so'mingizdan maksimal foyda olamiz"
  ];

  function initHeadingAnimation() {
    const heading = document.getElementById('animated-heading');
    if (!heading) return;

    let currentIndex = 0;

    setInterval(() => {
      heading.style.opacity = '0';
      heading.style.filter = 'blur(10px)';

      setTimeout(() => {
        currentIndex = (currentIndex + 1) % headingTexts.length;
        heading.textContent = headingTexts[currentIndex];
        heading.style.opacity = '1';
        heading.style.filter = 'blur(0px)';
      }, 300);
    }, 6000);
  }

  initHeadingAnimation();
  document.addEventListener('astro:after-swap', initHeadingAnimation);
</script>
