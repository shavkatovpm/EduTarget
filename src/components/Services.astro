---
// Telegram icon
const telegramIcon = `<path d="M22 2L11 13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M22 2L15 22L11 13L2 9L22 2Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`;

// Instagram icon
const instagramIcon = `<rect x="3" y="3" width="18" height="18" rx="5" ry="5" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor"/>`;

// Content strategy icon
const contentIcon = `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />`;

// Landing page icon
const landingIcon = `<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />`;

const services = [
  {
    icon: telegramIcon,
    title: 'Telegram reklama',
    what: 'Telegram Ads va mashhur kanallarda reklama. Bot orqali o\'quvchi yig\'ish.',
    forWhom: 'Telegram kanali yoki bot orqali o\'quvchi yig\'ayotgan ta\'lim markazlari.',
    result: 'Sifatli obunachilar va to\'g\'ridan-to\'g\'ri murojaatlar oshadi.'
  },
  {
    icon: instagramIcon,
    title: 'Instagram Target',
    what: 'Reklamangizni aniq auditoriyaga — yoshi, joyi, qiziqishlari bo\'yicha ko\'rsatamiz.',
    forWhom: 'Onlayn kurslar, repetitorlar, ta\'lim markazlari.',
    result: 'Aniq maqsadli auditoriyadan murojaatlar keladi, lead va ro\'yxatga olishlar ko\'payadi.'
  },
  {
    icon: contentIcon,
    title: 'Kontent strategiya',
    what: 'Ta\'lim markazingiz uchun to\'liq kontent reja va ijod.',
    forWhom: 'Ijtimoiy tarmoqlarda faol bo\'lmoqchi bo\'lgan ta\'lim brendlari.',
    result: 'Brendingiz kuchayadi, ishonch oshadi, organik o\'quvchilar keladi.'
  },
  {
    icon: landingIcon,
    title: 'Landing page va kreativlar',
    what: 'Reklama uchun maxsus sahifalar va vizual materiallar tayyorlash.',
    forWhom: 'Reklamadan maksimal konversiya olmoqchi bo\'lganlar.',
    result: 'Reklama samaradorligi 2-3 barobarga oshadi.'
  }
];
---

<section id="xizmatlar" class="section-padding min-h-screen flex flex-col justify-center">
  <div class="mx-auto max-w-[95%] px-2 sm:px-4">
    <!-- Services container with accent border -->
    <div class="rounded-3xl border-2 border-accent p-4 sm:p-6 md:p-8">
      <!-- Header -->
      <div class="mx-auto max-w-3xl text-center mb-8 md:mb-14">
        <h2 class="text-3xl font-bold text-dark md:text-4xl">
          Biz nima qilamiz?
        </h2>
        <p class="mt-4 text-dark/60">
          Ta'lim biznesiga ixtisoslashgan marketing xizmatlari
        </p>
      </div>

      <!-- Mobile: Accordion cards -->
      <div class="flex flex-col gap-3 md:hidden">
        {services.map((service) => (
          <div
            class="service-card group rounded-2xl border border-dark/10 bg-white overflow-hidden transition-all duration-300"
            data-service-card
          >
            <!-- Header (always visible) -->
            <button
              type="button"
              class="flex w-full items-start justify-between gap-3 p-5 text-left"
              data-service-trigger
            >
              <div class="flex items-start gap-3 flex-1 min-w-0">
                <div class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-accent/10 mt-0.5">
                  <svg class="h-6 w-6 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" set:html={service.icon} />
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="text-lg font-bold text-dark mb-2">
                    {service.title}
                  </h3>
                  <p class="text-sm text-dark/60 leading-relaxed">{service.what}</p>
                </div>
              </div>
              <svg
                class="h-5 w-5 shrink-0 text-accent transition-transform duration-300 mt-1"
                data-service-icon
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>

            <!-- Expandable content -->
            <div
              class="grid grid-rows-[0fr] transition-all duration-300 ease-out"
              data-service-content
            >
              <div class="overflow-hidden">
                <div class="px-4 pb-4 space-y-4">
                  <div class="rounded-xl bg-dark/5 p-3 space-y-4">
                    <!-- For whom -->
                    <div>
                      <div class="mb-1 flex items-center gap-2">
                        <div class="flex h-5 w-5 items-center justify-center rounded-full bg-accent/10">
                          <svg class="h-3 w-3 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                          </svg>
                        </div>
                        <span class="text-xs font-semibold text-dark/80">Kimlar uchun?</span>
                      </div>
                      <p class="text-sm text-dark/70">{service.forWhom}</p>
                    </div>

                    <!-- Results -->
                    <div class="border-t border-dark/10 pt-4">
                      <div class="mb-1 flex items-center gap-2">
                        <div class="flex h-5 w-5 items-center justify-center rounded-full bg-accent/10">
                          <svg class="h-3 w-3 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                          </svg>
                        </div>
                        <span class="text-xs font-semibold text-dark/80">Qanday natija?</span>
                      </div>
                      <p class="text-sm text-dark/70">{service.result}</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Desktop: 2x2 Grid cards -->
      <div class="hidden md:grid mx-auto max-w-5xl gap-5 md:grid-cols-2">
        {services.map((service) => (
          <div
            class="group relative flex flex-col overflow-hidden rounded-2xl border border-dark/10 bg-white p-5 transition-all duration-300 ease-out hover:border-accent/30 hover:shadow-xl hover:shadow-accent/10"
          >
            <div class="absolute inset-0 bg-accent opacity-0 transition-opacity duration-300 ease-out group-hover:opacity-5"></div>

            <div class="relative flex flex-1 flex-col">
              <div class="mb-5 flex items-center gap-3">
                <div class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-accent/10">
                  <svg class="h-6 w-6 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" set:html={service.icon} />
                </div>
                <h3 class="text-xl font-bold text-dark">{service.title}</h3>
              </div>

              <div class="flex-1">
                <div class="min-h-[80px] border-b border-dark/10 pb-4">
                  <div class="mb-1 flex items-center gap-2">
                    <div class="flex h-5 w-5 items-center justify-center rounded-full bg-accent/10">
                      <svg class="h-3 w-3 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                    </div>
                    <span class="text-xs font-semibold text-dark/80">Nima qilamiz?</span>
                  </div>
                  <p class="text-sm text-dark/70">{service.what}</p>
                </div>

                <div class="min-h-[80px] border-b border-dark/10 py-4">
                  <div class="mb-1 flex items-center gap-2">
                    <div class="flex h-5 w-5 items-center justify-center rounded-full bg-accent/10">
                      <svg class="h-3 w-3 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                      </svg>
                    </div>
                    <span class="text-xs font-semibold text-dark/80">Kimlar uchun?</span>
                  </div>
                  <p class="text-sm text-dark/70">{service.forWhom}</p>
                </div>

                <div class="min-h-[80px] pt-4">
                  <div class="mb-1 flex items-center gap-2">
                    <div class="flex h-5 w-5 items-center justify-center rounded-full bg-accent/10">
                      <svg class="h-3 w-3 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                      </svg>
                    </div>
                    <span class="text-xs font-semibold text-dark/80">Qanday natija?</span>
                  </div>
                  <p class="text-sm text-dark/70">{service.result}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Bottom subtitle -->
      <div class="mt-8 md:mt-10 text-center">
        <p class="text-base md:text-lg text-dark/60">
          Ta'lim biznesiga ixtisoslashgan yagona marketing agentligi
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  function initServiceCards() {
    const cards = document.querySelectorAll('[data-service-card]');

    cards.forEach((card) => {
      const trigger = card.querySelector('[data-service-trigger]');
      const content = card.querySelector('[data-service-content]') as HTMLElement;
      const icon = card.querySelector('[data-service-icon]') as HTMLElement;

      if (!trigger || !content || !icon) return;

      let isOpen = false;

      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        isOpen = !isOpen;

        if (isOpen) {
          cards.forEach((otherCard) => {
            if (otherCard !== card) {
              const otherContent = otherCard.querySelector('[data-service-content]') as HTMLElement;
              const otherIcon = otherCard.querySelector('[data-service-icon]') as HTMLElement;
              if (otherContent && otherIcon) {
                otherContent.style.gridTemplateRows = '0fr';
                otherIcon.style.transform = 'rotate(0deg)';
                otherCard.classList.remove('border-accent/30');
                otherCard.classList.add('border-dark/10');
              }
            }
          });
        }

        if (isOpen) {
          content.style.gridTemplateRows = '1fr';
          icon.style.transform = 'rotate(180deg)';
          card.classList.remove('border-dark/10');
          card.classList.add('border-accent/30');

          setTimeout(() => {
            const cardElement = card as HTMLElement;
            const cardRect = cardElement.getBoundingClientRect();
            const cardCenter = cardRect.top + cardRect.height / 2;
            const viewportCenter = window.innerHeight / 2;
            const scrollOffset = cardCenter - viewportCenter;
            window.scrollBy({ top: scrollOffset, behavior: 'smooth' });
          }, 350);
        } else {
          content.style.gridTemplateRows = '0fr';
          icon.style.transform = 'rotate(0deg)';
          card.classList.remove('border-accent/30');
          card.classList.add('border-dark/10');
        }
      });
    });
  }

  initServiceCards();
  document.addEventListener('astro:after-swap', initServiceCards);
</script>
