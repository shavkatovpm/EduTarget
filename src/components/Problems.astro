---
const problems = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    title: 'Reklamaga pul sarflaysiz, natija yo\'q',
    description: 'Ko\'pchilik ta\'lim markazlari reklamaga pul to\'laydi, lekin o\'quvchilar kam keladi. Biz faqat natija uchun ishlaymiz.'
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />`,
    title: 'Qaysi kanal ishlashini bilmaysiz',
    description: 'Telegram yoki Google — qaysi biri sizga mos? Biz tahlil qilib, to\'g\'ri kanalni tanlaymiz.'
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    title: 'Vaqtingiz yo\'q, tajribangiz kam',
    description: 'Marketing bo\'yicha mas\'uliyatni o\'z zimmamizga olamiz. Siz dars bering, biz o\'quvchi olib kelamiz.'
  }
];
---

<section class="section-padding min-h-screen flex flex-col justify-center bg-white">
  <div class="container-custom">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-dark md:text-4xl">
        Tanish muammolarmi?
      </h2>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3 md:gap-8">
      {problems.map((problem, index) => (
        <div
          class="group relative flex items-start gap-4 rounded-2xl border border-dark/10 bg-white p-6 transition-all hover:border-accent/20 hover:shadow-lg hover:shadow-accent/5 md:p-8"
          style={`animation-delay: ${index * 100}ms`}
        >
          <div class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-accent/10 text-accent">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={problem.icon} />
          </div>
          <div>
            <h3 class="text-lg font-semibold text-dark">
              {problem.title}
            </h3>
            <p class="mt-2 text-dark/70">
              {problem.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
